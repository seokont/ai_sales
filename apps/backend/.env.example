DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_seller?schema=public"
REDIS_URL="redis://localhost:6379"
# Set REDIS_ENABLED=false if Redis < 5.0 (e.g. Windows Redis 3.x). Scraper will run sync without queue.
# REDIS_ENABLED=false
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"
GROQ_API_KEY="your-groq-api-key"
PORT=3001
FRONTEND_URL="http://localhost:3000"
# Comma-separated CORS origins (add widget embed domains, e.g. https://myshop.com)
# CORS_ORIGINS="http://localhost:3000,https://myshop.com"
# Comma-separated admin emails (e.g. admin@example.com)
ADMIN_EMAILS="admin@example.com"
