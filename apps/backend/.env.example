DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_seller?schema=public"
REDIS_URL="redis://localhost:6379"
# Set REDIS_ENABLED=false if Redis < 5.0 (e.g. Windows Redis 3.x). Scraper will run sync without queue.
# REDIS_ENABLED=false
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"
GROQ_API_KEY="your-groq-api-key"
# If a company API key was exposed (e.g. in a screenshot or browser error), regenerate it in the dashboard.
PORT=3001
FRONTEND_URL="http://localhost:3000"
# Comma-separated CORS origins for dashboard / browser API (cookies). Widget embed uses public CORS on /widget* and /widget.js, so customer shop domains are not required here.
# CORS_ORIGINS="http://localhost:3000"
# Comma-separated admin emails (e.g. admin@example.com)
ADMIN_EMAILS="admin@example.com"
